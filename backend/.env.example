NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:password@localhost:5432/agritech
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Comma-separated for Vercel preview + production, e.g. https://app.vercel.app,https://preview.vercel.app
CORS_ORIGIN=http://localhost:5173
ENAM_API_KEY=
DISABLE_CRON=false
MOCK_MODE=false
AGMARKNET_API_KEY=
# Required on Render when DISABLE_CRON=true — used by cron-job.org
CRON_SECRET=
